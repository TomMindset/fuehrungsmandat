---
import { topics } from "@data/topics";
import Layout from "@layouts/Layout.astro";
---

<Layout
  title="Themen | Fuehrungsmandat.de"
  description="Themencluster zu Führungsmandat, Rollenklärung, lateraler Führung, Transformation, Stakeholder-Wirkung und KI und Führung."
  canonical="/themen"
>
  <main id="inhalt">
    <section class="surface-grid bg-paper py-16 sm:py-24">
      <div class="mx-auto max-w-7xl px-5 sm:px-8">
        <p class="mb-5 text-sm font-semibold uppercase tracking-[0.16em] text-copper">Themen</p>
        <h1 class="text-balance text-4xl font-semibold leading-tight text-graphite sm:text-5xl">Themenfelder für klare Führungsmandate.</h1>
        <p class="mt-7 max-w-3xl text-pretty text-lg leading-8 text-slategraph">
          Die Publikation bündelt wiederkehrende Führungsfragen in wenigen Clustern. Nicht als Modellwelt, sondern als Orientierung für reale Rollen- und Entscheidungssituationen.
        </p>
      </div>
    </section>
    <section class="bg-paper py-16 sm:py-20">
      <div class="mx-auto grid max-w-7xl gap-5 px-5 sm:px-8 lg:grid-cols-2">
        {topics.map((topic) => (
          <article id={topic.slug} class="scroll-mt-28 border border-graphite/12 bg-white p-7 shadow-quiet">
            <h2 class="text-2xl font-semibold text-graphite">{topic.title}</h2>
            <p class="mt-4 text-pretty leading-8 text-slategraph">{topic.description}</p>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>
