---
import Layout from "@layouts/Layout.astro";
---

<Layout
  title="Impressum | Fuehrungsmandat.de"
  description="Impressum von Fuehrungsmandat.de, persönliche Fachpublikation von Thomas Hoffmann."
  canonical="/impressum"
>
  <main id="inhalt">
    <section class="bg-paper py-16 sm:py-24">
      <div class="mx-auto max-w-3xl px-5 sm:px-8">
        <h1 class="text-4xl font-semibold text-graphite sm:text-5xl">Impressum</h1>
        <div class="mt-10 space-y-8 text-slategraph">
          <section>
            <h2 class="text-2xl font-semibold text-graphite">Angaben gemäß § 5 DDG</h2>
            <p class="mt-4 leading-8">
              Thomas Hoffmann<br />
              Mandat & Wirkung<br />
              Bahnhofstraße 75<br />
              71332 Waiblingen<br />
              Deutschland
            </p>
          </section>
          <section>
            <h2 class="text-2xl font-semibold text-graphite">Kontakt</h2>
            <p class="mt-4 leading-8">
              Telefon: <a class="font-semibold text-petrol hover:text-copper" href="tel:+4915234069461">+49 152 34 06 94 61</a><br />
              E-Mail: <a class="font-semibold text-petrol hover:text-copper" href="mailto:anfrage@mandat-wirkung.de">anfrage@mandat-wirkung.de</a>
            </p>
          </section>
          <section>
            <h2 class="text-2xl font-semibold text-graphite">Umsatzsteuer</h2>
            <p class="mt-4 leading-8">Es wird keine Umsatzsteuer-ID veröffentlicht.</p>
          </section>
          <section>
            <h2 class="text-2xl font-semibold text-graphite">Herausgeberhinweis</h2>
            <p class="mt-4 leading-8">
              Fuehrungsmandat.de ist eine persönliche Fachpublikation von Thomas Hoffmann. Mandat & Wirkung ist das vertrauliche Coaching-Angebot für Führungskräfte und Schlüsselpersonen.
            </p>
          </section>
        </div>
      </div>
    </section>
  </main>
</Layout>
