---
import { site } from "@data/site";
---

<section class="bg-ink py-16 text-paper sm:py-20">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div class="max-w-3xl">
      <p class="text-sm font-semibold uppercase tracking-[0.16em] text-copper">Mandat & Wirkung</p>
      <h2 class="mt-4 text-balance text-3xl font-semibold leading-tight sm:text-4xl">Eine konkrete Führungsfrage vertraulich einordnen.</h2>
      <p class="mt-6 text-pretty text-lg leading-8 text-paper/78">
        Wenn aus einer fachlichen Frage eine konkrete Führungs- oder Veränderungssituation wird, bietet Mandat & Wirkung einen vertraulichen Coaching-Rahmen.
      </p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a class="inline-flex min-h-12 items-center justify-center border border-copper bg-copper px-5 py-3 text-sm font-semibold text-white hover:bg-transparent" href={site.mandatWirkungContact}>
          Orientierungsgespräch anfragen
        </a>
        <a class="inline-flex min-h-12 items-center justify-center border border-paper/25 px-5 py-3 text-sm font-semibold text-paper hover:border-copper hover:text-copper" href={site.mandatWirkungUrl}>
          Mehr zu Mandat & Wirkung
        </a>
      </div>
    </div>
  </div>
</section>
