---
import type { CollectionEntry } from "astro:content";

interface Props {
  note: CollectionEntry<"notes">;
}

const { note } = Astro.props;
const href = `/notizen/${note.id.replace(/\.mdx?$/, "").replace(/\/index$/, "")}`;
const date = note.data.date.toLocaleDateString("de-DE", {
  day: "2-digit",
  month: "2-digit",
  year: "numeric"
});
---

<article class="border border-graphite/12 bg-white p-6 shadow-quiet">
  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-copper">{note.data.cluster} · {date}</p>
  <h2 class="mt-4 text-balance text-2xl font-semibold leading-tight text-graphite">
    <a class="hover:text-copper" href={href}>{note.data.title}</a>
  </h2>
  <p class="mt-4 text-pretty text-sm leading-7 text-slategraph">{note.data.description}</p>
  <a class="mt-6 inline-flex text-sm font-semibold text-petrol hover:text-copper" href={href}>Notiz lesen</a>
</article>
